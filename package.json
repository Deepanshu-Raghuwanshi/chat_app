{
  "name": "chat-system",
  "private": true,
  "scripts": {
    "docker:up": "docker-compose up -d --build",
    "docker:down": "docker-compose down",
    "docker:stop": "docker-compose stop",
    "docker:start": "docker-compose start",
    "docker:logs": "docker-compose logs -f",
    "check-all": "nx run-many --target=lint,typecheck,test --all",
    "generate:types": "node tools/scripts/generate-types.js",
    "docker:infra": "docker-compose up -d postgres mongodb redis kafka",
    "docker:services": "docker-compose up -d --build api-gateway auth-service user-service chat-service message-service notification-service frontend",
    "docker:api-gateway": "docker-compose up -d --build api-gateway",
    "docker:auth-service": "docker-compose up -d --build auth-service",
    "docker:user-service": "docker-compose up -d --build user-service",
    "docker:chat-service": "docker-compose up -d --build chat-service",
    "docker:message-service": "docker-compose up -d --build message-service",
    "docker:notification-service": "docker-compose up -d --build notification-service",
    "docker:frontend": "docker-compose up -d --build frontend"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/websockets": "^11.1.14",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/socket.io": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.4.7",
    "mongoose": "^9.2.3",
    "nestjs-pino": "^4.6.0",
    "next": "^15.5.0",
    "pg": "^8.13.3",
    "pino": "^10.3.1",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nx/eslint": "^22.5.4",
    "@nx/jest": "^22.5.3",
    "@nx/js": "^22.5.3",
    "@nx/linter": "^19.8.4",
    "@nx/nest": "^22.5.3",
    "@nx/next": "^22.5.3",
    "@nx/node": "^22.5.3",
    "@nx/react": "^22.5.3",
    "@nx/vite": "^22.5.4",
    "@nx/vitest": "^22.5.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.2",
    "@types/pg": "^8.11.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "dotenv": "^16.4.7",
    "eslint": "^9.12.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "jsdom": "^28.1.0",
    "jsonc-parser": "^3.3.1",
    "nx": "^22.5.3",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "@nestjs/core",
      "sharp"
    ]
  }
}