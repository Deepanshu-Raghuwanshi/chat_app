{
  "name": "chat-system",
  "private": true,
  "scripts": {
    "start:infra": "docker-compose up -d",
    "stop:infra": "docker-compose down",
    "infra:logs": "docker-compose logs -f",
    "check-all": "nx run-many --target=lint,typecheck,test --all",
    "generate:types": "node tools/scripts/generate-types.js",
    "start:all": "nx run-many --target=serve --all --parallel=10",
    "start:api-gateway": "nx serve api-gateway",
    "start:auth-service": "nx serve auth-service",
    "start:user-service": "nx serve user-service",
    "start:chat-service": "nx serve chat-service",
    "start:message-service": "nx serve message-service",
    "start:notification-service": "nx serve notification-service",
    "start:frontend": "nx serve frontend",
    "prisma:migrate:auth": "pnpm prisma migrate dev --schema apps/auth-service/prisma/schema.prisma --url \"postgresql://postgres:postgres@localhost:5432/chat_db?schema=auth\"",
    "prisma:migrate:user": "pnpm prisma migrate dev --schema apps/user-service/prisma/schema.prisma --url \"postgresql://postgres:postgres@localhost:5432/chat_db?schema=user_service\"",
    "prisma:generate": "pnpm prisma generate --schema apps/auth-service/prisma/schema.prisma && pnpm prisma generate --schema apps/user-service/prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.16",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.14",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/socket.io": "^3.0.2",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clsx": "^2.1.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "handlebars": "^4.7.8",
    "kafkajs": "^2.2.4",
    "lucide-react": "^0.577.0",
    "mongoose": "^9.2.3",
    "nestjs-pino": "^4.6.0",
    "next": "^15.5.0",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.3",
    "pino": "^10.3.1",
    "prisma": "^7.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@nx/eslint": "^22.5.4",
    "@nx/jest": "^22.5.3",
    "@nx/js": "^22.5.3",
    "@nx/linter": "^19.8.4",
    "@nx/nest": "^22.5.3",
    "@nx/next": "^22.5.3",
    "@nx/node": "^22.5.3",
    "@nx/react": "^22.5.3",
    "@nx/vite": "^22.5.4",
    "@nx/vitest": "^22.5.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.2",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
