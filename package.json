    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.12.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "jsdom": "^28.1.0",
    "jsonc-parser": "^3.3.1",
    "nx": "^22.5.3",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "@nestjs/core",
      "sharp"
    ]
  }
}
