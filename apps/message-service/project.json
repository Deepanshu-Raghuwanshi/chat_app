{
  "name": "message-service",
  "tags": ["layer:infrastructure", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/message-service"],
      "options": {
          "command": "pnpm tsc -p tsconfig.message-service.json && pnpm tsc-alias -p tsconfig.message-service.json" 
      }
    },
    "lint": {
      "executor": "@nx/linter:eslint"
    },
    "test": {
      "executor": "@nx/jest:jest"
    },
    "typecheck": {
      "executor": "@nx/js:tsc"
    }
  }
}
