{
  "name": "message-service",
  "tags": ["layer:infrastructure", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/message-service"],
      "options": {
        "command": "pnpm tsc -p tsconfig.message-service.json && pnpm tsc-alias -p tsconfig.message-service.json"
      }
    },
    "lint": {},
    "test": {},
    "typecheck": {},
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=tsconfig.message-service.json node --watch -r ts-node/register -r tsconfig-paths/register apps/message-service/src/main.ts"
      }
    }
  }
}
