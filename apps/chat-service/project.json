{
  "name": "chat-service",
  "tags": ["layer:infrastructure", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/chat-service"],
      "options": {
        "command": "pnpm tsc -p tsconfig.chat-service.json && pnpm tsc-alias -p tsconfig.chat-service.json"
      }
    },
    "lint": {},
    "test": {},
    "typecheck": {},
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cross-env TS_NODE_PROJECT=tsconfig.chat-service.json ts-node-dev -r tsconfig-paths/register --respawn apps/chat-service/src/main.ts"
      }
    }
  }
}
