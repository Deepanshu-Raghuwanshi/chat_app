{
  "name": "api-gateway",
  "tags": ["layer:infrastructure", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/apps/api-gateway"],
      "options": {
        "command": "pnpm tsc -p tsconfig.api-gateway.json && pnpm tsc-alias -p tsconfig.api-gateway.json"
      }
    },
    "lint": {},
    "test": {},
    "typecheck": {},
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cross-env TS_NODE_PROJECT=tsconfig.api-gateway.json ts-node-dev -r tsconfig-paths/register --respawn apps/api-gateway/src/main.ts"
      }
    }
  }
}
