{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "esModuleInterop": true,
    "allowJs": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "types": ["node", "mocha", "chai", "sinon"]
  },
  "ts-node": {
    "esm": false
  },
  "include": [
    "apps/**/*.ts",
    "libs/**/*.ts"
  ]
}
