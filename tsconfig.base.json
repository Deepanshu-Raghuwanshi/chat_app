{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "strict": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {
      "@shared-types/*": [
        "libs/shared-types/*"
      ],
      "@shared-utils/*": [
        "libs/shared-utils/*"
      ],
      "@shared-exceptions/*": [
        "libs/shared-exceptions/src/*"
      ],
      "@shared-logger/*": [
        "libs/shared-logger/src/*"
      ],
      "@shared-validation/*": [
        "libs/shared-validation/src/*"
      ],
      "@kafka-events/*": [
        "libs/kafka-events/src/*"
      ]
    }
  }
}